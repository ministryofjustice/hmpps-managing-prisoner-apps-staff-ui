{%- from "govuk/components/breadcrumbs/macro.njk" import govukBreadcrumbs -%}
{%- from "govuk/components/button/macro.njk" import govukButton -%}
{%- from "govuk/components/character-count/macro.njk" import govukCharacterCount -%}
{%- from "govuk/components/error-summary/macro.njk" import govukErrorSummary -%}
{%- from "govuk/components/textarea/macro.njk" import govukTextarea -%}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{%- from "components/appMessages/macro.njk" import appMessages -%}
{% extends "../../../partials/layout.njk" %}
{% set pageTitle = applicationName + " - " + title %}
{% set mainClasses = "app-container govuk-body applications-landing-page" %}
{% block beforeContent %}
  <div class="govuk-body govuk-width-container">
    {{ govukBreadcrumbs({
      items: [
        {
          text: "Digital Prisons Services",
          href: dpsUrl
        },
        {
          text: "Applications",
          href: "/"
        },
        {
          text: "View all applications",
          href: "/applications"
        }
      ]
    }) }}
  </div>
{% endblock %}
{% block content %}
  <div class="govuk-modal-dialogue-inert-container">
    <div class="govuk-body govuk-width-container">
      {% if errors %}
        {% set textFieldError = errors.Messages if errors.Messages else undefined %}
        {% set messageFieldError = [] %}
        {% if textFieldError %}
          {% set messageFieldError = { text: textFieldError.text } %}
        {% endif %}
        {% set visibilityErrorMessage = [] %}
        {% if errors.messageVisibility %}
          {% set visibilityErrorMessage = { text: errors.messageVisibility.text } %}
        {% endif %}
        {% set errorList = [] %}
        {% if textFieldError %}
          {% set errorList = errorList.concat([{ text: textFieldError.text, href: "#comment" }]) %}
        {% endif %}
        {% if errors.messageVisibility %}
          {% set errorList = errorList.concat([{ text: errors.messageVisibility.text, href: "#visibility" }]) %}
        {% endif %}
        {{ govukErrorSummary({
          titleText: "There is a problem",
          errorList: errorList
        }) }}
      {% endif %}
      <h1 class="govuk-heading-xl govuk-!-margin-top-0">{{ applicationType.name }}</h1>
      {% set activeTab = 'comments' %}
      {% include "../partials/sub-navigation.njk" %}
      <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
          <h2 class="govuk-heading-m">Messages and replies</h2>
          <div class="govuk-!-margin-bottom-4">
            {{ appMessages({ items: comments }) }}
          </div>
          {% if not isClosed %}
            <form method="POST" id="application-comments-form">
              <input type="hidden" name="_csrf" value="{{ csrfToken }}"/> {{ govukCharacterCount({
                name: "comment",
                id: "comment",
                maxlength: 1000,
                threshold: 75,
                value: comment,
                label: {
                  text: "Send message",
                  classes: "govuk-label--s govuk-!-margin-bottom-4",
                  isPageHeading: true
                },
                errorMessage: messageFieldError
              }) }}
              {{ govukRadios({
                name: "visibility",
                errorMessage: visibilityErrorMessage if errors.messageVisibility else undefined,
                fieldset: {
                  legend: {
                    text: "Who will see this message?",
                    isPageHeading: true,
                    classes: "govuk-fieldset__legend--s"
                  }
                },
                hint: {
                  text: "This message will be shown to:"
                },
                items: [
                  {
                    value: "staff-only",
                    text: "Staff only",
                    checked: visibility === "staff-only"
                  },
                  {
                    value: "prisoner-and-staff",
                    text: "Prisoner and staff",
                    checked: visibility === "prisoner-and-staff",
                    hint: {
                      text: "This will be seen by the prisoner in the Launchpad prisons only"
                    }
                  }
                ]
              }) }}
              {{ govukButton({
                text: "Send",
                classes: "govuk-button--primary"
              }) }}
            </form>
          {% endif %}
        </div>
      </div>
    </div>
    <button type="button" id="visibility-modal-trigger" class="govuk-visually-hidden"></button>
    <div
      class="govuk-modal-dialogue"
      data-trigger="#visibility-modal-trigger"
      data-inert-container=".govuk-modal-dialogue-inert-container">
      <div class="govuk-modal-dialogue__wrapper">
        <dialog
          class="govuk-modal-dialogue__box"
          aria-labelledby="visibility-modal-title"
          aria-modal="true"
          role="dialog"
          tabindex="-1">
          <div class="govuk-modal-dialogue__header">
            <button
              type="button"
              class="govuk-button govuk-modal-dialogue__close"
              aria-label="Close dialog"
              data-element="govuk-modal-dialogue-close">x</button>
          </div>
          <div class="govuk-modal-dialogue__content">
            <h2 class="govuk-modal-dialogue__heading govuk-heading-l" id="visibility-modal-title">Should this message be seen by the
              prisoner?</h2>
            <div class="govuk-button-group">
              <button type="button" class="govuk-button" id="visibility-modal-confirm">Yes</button>
              <button type="button" class="govuk-link app-link-button" id="visibility-modal-cancel">No, go back</button>
            </div>
          </div>
        </dialog>
      </div>
      <div class="govuk-modal-dialogue__backdrop"></div>
    </div>
  </div>
{% endblock %}
