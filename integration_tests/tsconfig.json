{
  "compilerOptions": {
    "target": "ES2020",
    "moduleResolution": "node",
    "noEmit": true,
    "lib": ["ES2020", "dom"],
    "types": ["cypress", "express", "express-session"],
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": ["**/*.ts"],
  "exclude": ["Cypress (deprecated)/**"]
}
